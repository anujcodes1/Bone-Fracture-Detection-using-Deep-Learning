{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "functions": {
    "app.py": {
      "includeFiles": "{backend/**,static/**,model/**}",
      "excludeFiles": "{dataset/**,uploads/**,outputs/**,reports/**,venv/**,__pycache__/**,*.db,*.sqlite,*.sqlite3}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.py"
    }
  ]
}
